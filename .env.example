# =============================================================
# Patch Window — environment variables
# Copy to .env.local for local development
# All variables marked REQUIRED must be set — no silent fallback
# =============================================================

# Database (PostgreSQL via porsager/postgres)
# REQUIRED
DATABASE_URL=postgresql://patchwindow:changeme@localhost:5432/patchwindow

# Resend — transactional email
# REQUIRED in production (newsletter + corrections notifications)
RESEND_API_KEY=re_...

# Next.js
NODE_ENV=development
